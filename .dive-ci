rules:
  # kcov/kcov:v42 is Debian 11 (bullseye); apt-get upgrade in our RUN layer
  # overwrites base-image package files, leaving old versions in the lower
  # layers.  This is structurally unavoidable without squashing or a multi-stage
  # build.  Measured baseline efficiency is ~0.696; threshold set below to
  # allow for minor variation across builds.
  lowestEfficiency: 0.65
  # apt-get upgrade rewrites many base-image packages.  Each overwritten file
  # counts as "user-wasted bytes" even though the upgrade is intentional
  # (security patches).  The measured baseline is ~108% which exceeds dive's
  # allowed config range (0–1), so this rule must be disabled for this image.
  highestUserWastedPercent: disabled
  highestWastedBytes: disabled
